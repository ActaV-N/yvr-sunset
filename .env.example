# Instagram Graph API (manual refresh every ~60 days)
IG_USER_ID=
IG_ACCESS_TOKEN=
IG_GRAPH_VERSION=v23.0

# Cloudflare R2 (S3-compatible)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=yvr-sunset
R2_PUBLIC_BASE_URL=

# Unsplash (free tier, register at https://unsplash.com/developers)
UNSPLASH_ACCESS_KEY=

# Ticketmaster Discovery API (free tier 5000/day, register at https://developer.ticketmaster.com)
TICKETMASTER_API_KEY=

# ElevenLabs (free tier 10k chars/month with attribution, paid Starter $5/30k from 30,000)
# https://elevenlabs.io → Profile → API Keys
ELEVENLABS_API_KEY=
# Voice ID — pick from https://elevenlabs.io/app/voice-library or default voices
# (e.g., 21m00Tcm4TlvDq8ikWAM = Rachel, pNInz6obpgDQGcFmaJgB = Adam)
ELEVENLABS_VOICE_ID=

# Geo override (defaults are Vancouver)
VANCOUVER_LAT=49.2827
VANCOUVER_LNG=-123.1207
VANCOUVER_TZ=America/Vancouver
