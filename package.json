    "dotenv": "^16.4.5",
    "mime-types": "^2.1.35",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "remotion": "^4.0.380",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/mime-types": "^2.1.4",
